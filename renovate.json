{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>konflux-ci/mintmaker-presets:refresh-rpm-lockfiles"
    ],
    "automergeStrategy": "rebase",
    "automergeType": "pr",
    "gomod": {
        "enabled": false
    },
    "git-submodules": {
        "enabled": true,
        "packageRules": [
            {
                "addLabels": [
                    "allow-automatic-merge"
                ],
                "additionalBranchPrefix": "telco5g-konflux-",
                "matchPackageNames": [
                    "https://github.com/openshift-kni/telco5g-konflux"
                ],
                "schedule": [
                    "at any time"
                ]
            }
        ]
    },
    "packageRules": [
        {
            "matchUpdateTypes": [
                "minor"
            ],
            "enabled": false
        },
        {
            "addLabels": [
                "allow-automatic-merge"
            ],
            "matchManagers": [
                "rpm-lockfile"
            ]
        },
        {
            "addLabels": [
                "allow-automatic-merge"
            ],
            "enabled": true,
            "ignoreTests": false,
            "matchDatasources": [
                "docker"
            ],
            "matchManagers": [
                "dockerfile"
            ],
            "matchFileNames": [
                ".konflux/**"
            ],
            "matchUpdateTypes": [
                "digest"
            ],
            "platformAutomerge": true,
            "schedule": [
                "at any time"
            ]
        }
    ],
    "prConcurrentLimit": 0,
    "pruneBranchAfterAutomerge": true,
    "tekton": {
        "enabled": true,
        "managerFilePatterns": [
            "/\\.yaml$/",
            "/\\.yml$/"
        ],
        "ignoreTests": false,
        "includePaths": [
            ".tekton/**"
        ],
        "packageRules": [
            {
                "addLabels": [
                    "allow-automatic-merge"
                ],
                "matchUpdateTypes": [
                    "digest"
                ]
            }
        ],
        "platformAutomerge": true
    }
}
